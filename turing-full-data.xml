<?xml version="1.0" encoding="UTF-8"?>
<!--
    图灵知识图谱 · 实例数据（第 3 层）
    通过 owl:imports 引入 turing-owl.xml（进而引入 turing-rdfs.xml）
    只包含：手工编写的结构化实例 + NER 实体抽取生成的实例
-->
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:turing="http://www.example.org/turing#"
    xml:base="http://www.example.org/turing">

    <!-- ==================== 本体引用 ==================== -->
    <owl:Ontology rdf:about="http://www.example.org/turing">
        <rdfs:comment>图灵知识图谱 - 实例数据层</rdfs:comment>
        <!-- 通过 owl:imports 引入 OWL 层（进而引入 RDFS 层） -->
        <owl:imports rdf:resource="ontology/turing-owl.xml"/>
        <!-- 同时引入 NER 实体抽取结果 -->
        <owl:imports rdf:resource="ner/output/ner_integrated_instances.xml"/>
    </owl:Ontology>

    <!-- ==================== 手工编写的结构化实例 ==================== -->

    <!-- 人物 -->
    <turing:Person rdf:ID="AlanTuring">
        <rdfs:label>艾伦·图灵</rdfs:label>
        <turing:description>艾伦·图灵（1912-1954），英国数学家、逻辑学家、计算机科学家，被视为计算机科学之父</turing:description>
        <turing:participatedIn rdf:resource="#Event_Birth"/>
        <turing:participatedIn rdf:resource="#Event_CambridgeEnrollment"/>
        <turing:participatedIn rdf:resource="#Event_TuringMachinePaper"/>
        <turing:participatedIn rdf:resource="#Event_PrincetonPhD"/>
        <turing:participatedIn rdf:resource="#Event_BletchleyPark"/>
        <turing:participatedIn rdf:resource="#Event_BombeDesign"/>
        <turing:participatedIn rdf:resource="#Event_ManchesterUniversity"/>
        <turing:participatedIn rdf:resource="#Event_TuringTestPaper"/>
        <turing:participatedIn rdf:resource="#Event_Trial"/>
        <turing:participatedIn rdf:resource="#Event_Death"/>
        <turing:participatedIn rdf:resource="#Event_GovernmentApology"/>
        <turing:participatedIn rdf:resource="#Event_RoyalPardon"/>
        <turing:wrote rdf:resource="#Publication_ComputableNumbers"/>
        <turing:wrote rdf:resource="#Publication_ComputingIntelligence"/>
        <turing:wrote rdf:resource="#Publication_ChemicalBasis"/>
        <turing:wrote rdf:resource="#Publication_ACEReport"/>
        <turing:received rdf:resource="#Award_FRS"/>
        <turing:received rdf:resource="#Award_OBE"/>
        <turing:received rdf:resource="#Award_RoyalPardon"/>
    </turing:Person>

    <!-- 事件 -->
    <turing:PersonalEvent rdf:ID="Event_Birth">
        <rdfs:label>图灵出生</rdfs:label>
        <turing:eventDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1912-06-23</turing:eventDate>
        <turing:happenedAt rdf:resource="#Location_London"/>
        <turing:description>艾伦·图灵出生于伦敦</turing:description>
    </turing:PersonalEvent>

    <turing:AcademicEvent rdf:ID="Event_CambridgeEnrollment">
        <rdfs:label>剑桥入学</rdfs:label>
        <turing:eventDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1931-10-01</turing:eventDate>
        <turing:happenedAt rdf:resource="#Location_Cambridge"/>
        <turing:description>进入剑桥大学国王学院学习</turing:description>
    </turing:AcademicEvent>

    <turing:AcademicEvent rdf:ID="Event_TuringMachinePaper">
        <rdfs:label>发表图灵机论文</rdfs:label>
        <turing:eventDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1936-11-30</turing:eventDate>
        <turing:happenedAt rdf:resource="#Location_London"/>
        <turing:description>发表《论可计算数及其在判定问题中的应用》</turing:description>
    </turing:AcademicEvent>

    <turing:AcademicEvent rdf:ID="Event_PrincetonPhD">
        <rdfs:label>普林斯顿博士</rdfs:label>
        <turing:eventDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1938-06-01</turing:eventDate>
        <turing:happenedAt rdf:resource="#Location_Princeton"/>
        <turing:description>获普林斯顿大学博士学位</turing:description>
    </turing:AcademicEvent>

    <turing:AcademicEvent rdf:ID="Event_BletchleyPark">
        <rdfs:label>加入布莱切利园</rdfs:label>
        <turing:eventDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1939-09-01</turing:eventDate>
        <turing:happenedAt rdf:resource="#Location_Bletchley"/>
        <turing:description>加入密码破译机构</turing:description>
    </turing:AcademicEvent>

    <turing:AcademicEvent rdf:ID="Event_BombeDesign">
        <rdfs:label>设计Bombe破译机</rdfs:label>
        <turing:eventDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1940-01-01</turing:eventDate>
        <turing:happenedAt rdf:resource="#Location_Bletchley"/>
        <turing:description>研发恩尼格玛破解设备</turing:description>
    </turing:AcademicEvent>

    <turing:AcademicEvent rdf:ID="Event_ManchesterUniversity">
        <rdfs:label>曼彻斯特大学任教</rdfs:label>
        <turing:eventDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1948-10-01</turing:eventDate>
        <turing:happenedAt rdf:resource="#Location_Manchester"/>
        <turing:description>任计算机实验室副主任</turing:description>
    </turing:AcademicEvent>

    <turing:AcademicEvent rdf:ID="Event_TuringTestPaper">
        <rdfs:label>发表图灵测试论文</rdfs:label>
        <turing:eventDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1950-10-01</turing:eventDate>
        <turing:happenedAt rdf:resource="#Location_Manchester"/>
        <turing:description>发表《计算机与智能》</turing:description>
    </turing:AcademicEvent>

    <turing:PersonalEvent rdf:ID="Event_Trial">
        <rdfs:label>图灵审判</rdfs:label>
        <turing:eventDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1952-03-31</turing:eventDate>
        <turing:happenedAt rdf:resource="#Location_Wilmslow"/>
        <turing:description>因同性恋行为被判化学阉割</turing:description>
    </turing:PersonalEvent>

    <turing:PersonalEvent rdf:ID="Event_Death">
        <rdfs:label>图灵逝世</rdfs:label>
        <turing:eventDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1954-06-07</turing:eventDate>
        <turing:happenedAt rdf:resource="#Location_Wilmslow"/>
        <turing:description>因氰化物中毒逝世</turing:description>
    </turing:PersonalEvent>

    <turing:HistoricalEvent rdf:ID="Event_GovernmentApology">
        <rdfs:label>英国政府道歉</rdfs:label>
        <turing:eventDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2009-09-10</turing:eventDate>
        <turing:happenedAt rdf:resource="#Location_London"/>
        <turing:description>英国政府正式道歉</turing:description>
    </turing:HistoricalEvent>

    <turing:HistoricalEvent rdf:ID="Event_RoyalPardon">
        <rdfs:label>皇家赦免</rdfs:label>
        <turing:eventDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2013-12-24</turing:eventDate>
        <turing:happenedAt rdf:resource="#Location_London"/>
        <turing:description>获英国皇家赦免</turing:description>
    </turing:HistoricalEvent>

    <!-- 地点 -->
    <turing:City rdf:ID="Location_London">
        <rdfs:label>伦敦</rdfs:label>
        <turing:country>英国</turing:country>
        <turing:description>图灵出生地</turing:description>
    </turing:City>

    <turing:City rdf:ID="Location_Cambridge">
        <rdfs:label>剑桥</rdfs:label>
        <turing:country>英国</turing:country>
        <turing:description>剑桥大学所在地</turing:description>
    </turing:City>

    <turing:City rdf:ID="Location_Princeton">
        <rdfs:label>普林斯顿</rdfs:label>
        <turing:country>美国</turing:country>
        <turing:description>普林斯顿大学所在地</turing:description>
    </turing:City>

    <turing:City rdf:ID="Location_Bletchley">
        <rdfs:label>布莱切利</rdfs:label>
        <turing:country>英国</turing:country>
        <turing:description>布莱切利园所在地</turing:description>
    </turing:City>

    <turing:City rdf:ID="Location_Manchester">
        <rdfs:label>曼彻斯特</rdfs:label>
        <turing:country>英国</turing:country>
        <turing:description>曼彻斯特大学所在地</turing:description>
    </turing:City>

    <turing:City rdf:ID="Location_Wilmslow">
        <rdfs:label>威尔姆斯洛</rdfs:label>
        <turing:country>英国</turing:country>
        <turing:description>图灵晚年居住地及逝世地</turing:description>
    </turing:City>

    <!-- 学术著作 -->
    <turing:Paper rdf:ID="Publication_ComputableNumbers">
        <rdfs:label>论可计算数及其在判定问题中的应用</rdfs:label>
        <turing:publicationYear rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">1936</turing:publicationYear>
        <turing:description>提出图灵机概念，奠定计算理论基础</turing:description>
    </turing:Paper>

    <turing:Paper rdf:ID="Publication_ComputingIntelligence">
        <rdfs:label>计算机与智能</rdfs:label>
        <turing:publicationYear rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">1950</turing:publicationYear>
        <turing:description>提出图灵测试，开启人工智能研究</turing:description>
    </turing:Paper>

    <turing:Paper rdf:ID="Publication_ChemicalBasis">
        <rdfs:label>形态发生的化学基础</rdfs:label>
        <turing:publicationYear rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">1952</turing:publicationYear>
        <turing:description>数学生物学领域开创性工作</turing:description>
    </turing:Paper>

    <turing:TechnicalReport rdf:ID="Publication_ACEReport">
        <rdfs:label>ACE计算机设计报告</rdfs:label>
        <turing:publicationYear rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">1945</turing:publicationYear>
        <turing:description>早期存储程序计算机设计方案</turing:description>
    </turing:TechnicalReport>

    <!-- 荣誉奖项 -->
    <turing:AcademicAward rdf:ID="Award_FRS">
        <rdfs:label>英国皇家学会院士</rdfs:label>
        <turing:awardYear rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">1951</turing:awardYear>
        <turing:description>当选皇家学会院士</turing:description>
    </turing:AcademicAward>

    <turing:HonoraryTitle rdf:ID="Award_OBE">
        <rdfs:label>大英帝国勋章</rdfs:label>
        <turing:awardYear rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">1946</turing:awardYear>
        <turing:description>表彰二战密码破译贡献</turing:description>
    </turing:HonoraryTitle>

    <turing:AcademicAward rdf:ID="Award_Turing">
        <rdfs:label>图灵奖</rdfs:label>
        <turing:awardYear rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">1966</turing:awardYear>
        <turing:description>以他命名的计算机界最高奖</turing:description>
    </turing:AcademicAward>

    <turing:HonoraryTitle rdf:ID="Award_Banknote">
        <rdfs:label>英国50英镑纸币</rdfs:label>
        <turing:awardYear rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">2021</turing:awardYear>
        <turing:description>头像印于新版50英镑纸币</turing:description>
    </turing:HonoraryTitle>

    <turing:HonoraryTitle rdf:ID="Award_RoyalPardon">
        <rdfs:label>皇家赦免</rdfs:label>
        <turing:awardYear rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">2013</turing:awardYear>
        <turing:description>英国女王签署赦免令</turing:description>
    </turing:HonoraryTitle>

    <turing:HonoraryTitle rdf:ID="Award_TuringAct">
        <rdfs:label>艾伦·图灵法案</rdfs:label>
        <turing:awardYear rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">2017</turing:awardYear>
        <turing:description>赦免历史上因同性恋定罪者</turing:description>
    </turing:HonoraryTitle>

    <!-- ==================== RDF Reification：多元关系 ==================== -->
    <!-- 布莱切利园工作期（包含时间范围和角色信息） -->
    <rdf:Statement rdf:ID="Statement_BletchleyWork">
        <rdf:subject rdf:resource="#AlanTuring"/>
        <rdf:predicate rdf:resource="http://www.example.org/turing#participatedIn"/>
        <rdf:object rdf:resource="#Event_BletchleyPark"/>
        <turing:period>1939-1945</turing:period>
        <turing:role>首席密码学家</turing:role>
    </rdf:Statement>

</rdf:RDF>
