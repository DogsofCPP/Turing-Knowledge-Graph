<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:turing="http://www.example.org/turing#"
    xml:base="http://www.example.org/turing">

    <!--
        图灵知识图谱 · OWL 约束定义（第 2 层）
        通过 owl:imports 引入 turing-rdfs.xml 中的类和属性
        只添加 RDFS 无法表达的 OWL 特有约束：
            - 函数性属性（FunctionalProperty）
            - 基数约束（minCardinality）
    -->

    <!-- ==================== 本体声明 + imports ==================== -->
    <owl:Ontology rdf:about="http://www.example.org/turing">
        <rdfs:comment>图灵知识图谱本体 - OWL 约束层</rdfs:comment>
        <owl:versionInfo>1.0</owl:versionInfo>
        <!-- 通过 owl:imports 引入 RDFS 层（类层次 + 属性定义） -->
        <owl:imports rdf:resource="turing-rdfs.xml"/>
    </owl:Ontology>

    <!-- ==================== OWL 属性特征：函数性 ==================== -->
    <!-- eventDate 是函数性属性：一个事件只能有一个日期 -->
    <rdf:Property rdf:ID="eventDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </rdf:Property>

    <!-- publicationYear 是函数性属性：一本著作只能有一个发表年份 -->
    <rdf:Property rdf:ID="publicationYear">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </rdf:Property>

    <!-- awardYear 是函数性属性：一个奖项只能有一个颁发年份 -->
    <rdf:Property rdf:ID="awardYear">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </rdf:Property>

    <!-- description 是函数性属性：每个实体最多一条描述 -->
    <rdf:Property rdf:ID="description">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </rdf:Property>

    <!-- country 是函数性属性：每个地点只能属于一个国家 -->
    <rdf:Property rdf:ID="country">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </rdf:Property>

    <!-- ==================== OWL 类约束：子类与等价性 ==================== -->
    <!-- Paper ⊑ Publication -->
    <owl:Class rdf:ID="Paper">
        <rdfs:subClassOf rdf:resource="#Publication"/>
    </owl:Class>

    <!-- Book ⊑ Publication -->
    <owl:Class rdf:ID="Book">
        <rdfs:subClassOf rdf:resource="#Publication"/>
    </owl:Class>

    <!-- TechnicalReport ⊑ Publication -->
    <owl:Class rdf:ID="TechnicalReport">
        <rdfs:subClassOf rdf:resource="#Publication"/>
    </owl:Class>

    <!-- AcademicEvent ⊑ Event -->
    <owl:Class rdf:ID="AcademicEvent">
        <rdfs:subClassOf rdf:resource="#Event"/>
    </owl:Class>

    <!-- PersonalEvent ⊑ Event -->
    <owl:Class rdf:ID="PersonalEvent">
        <rdfs:subClassOf rdf:resource="#Event"/>
    </owl:Class>

    <!-- HistoricalEvent ⊑ Event -->
    <owl:Class rdf:ID="HistoricalEvent">
        <rdfs:subClassOf rdf:resource="#Event"/>
    </owl:Class>

    <!-- City ⊑ Location -->
    <owl:Class rdf:ID="City">
        <rdfs:subClassOf rdf:resource="#Location"/>
    </owl:Class>

    <!-- Country ⊑ Location -->
    <owl:Class rdf:ID="Country">
        <rdfs:subClassOf rdf:resource="#Location"/>
    </owl:Class>

    <!-- InstitutionLocation ⊑ Location -->
    <owl:Class rdf:ID="InstitutionLocation">
        <rdfs:subClassOf rdf:resource="#Location"/>
    </owl:Class>

    <!-- AcademicAward ⊑ Award -->
    <owl:Class rdf:ID="AcademicAward">
        <rdfs:subClassOf rdf:resource="#Award"/>
    </owl:Class>

    <!-- HonoraryTitle ⊑ Award -->
    <owl:Class rdf:ID="HonoraryTitle">
        <rdfs:subClassOf rdf:resource="#Award"/>
    </owl:Class>

    <!-- ==================== OWL 基数约束 ==================== -->
    <!-- 每个事件至少有一个发生地点（语义约束，非严格推理） -->
    <owl:Class rdf:ID="Event">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#happenedAt"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

</rdf:RDF>
