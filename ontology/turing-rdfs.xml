<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:turing="http://www.example.org/turing#"
    xml:base="http://www.example.org/turing">

    <!-- 类定义 -->
    <!-- 人物 -->
    <rdfs:Class rdf:ID="Person" rdfs:label="人物">
        <rdfs:comment>表示艾伦·图灵本人及相关人物</rdfs:comment>
    </rdfs:Class>

    <!-- 事件类及其子类 -->
    <rdfs:Class rdf:ID="Event" rdfs:label="事件">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Resource"/>
        <rdfs:comment>表示事件，包括学术事件、个人事件和历史事件</rdfs:comment>
    </rdfs:Class>

    <rdfs:Class rdf:ID="AcademicEvent" rdfs:label="学术事件">
        <rdfs:subClassOf rdf:resource="#Event"/>
        <rdfs:comment>表示学术相关的事件，如入学、发表论文、获得学位等</rdfs:comment>
    </rdfs:Class>

    <rdfs:Class rdf:ID="PersonalEvent" rdfs:label="个人事件">
        <rdfs:subClassOf rdf:resource="#Event"/>
        <rdfs:comment>表示个人生活相关的事件，如出生、审判、逝世等</rdfs:comment>
    </rdfs:Class>

    <rdfs:Class rdf:ID="HistoricalEvent" rdfs:label="历史事件">
        <rdfs:subClassOf rdf:resource="#Event"/>
        <rdfs:comment>表示具有历史意义的事件，如政府道歉、皇家赦免等</rdfs:comment>
    </rdfs:Class>

    <!-- 地点类及其子类 -->
    <rdfs:Class rdf:ID="Location" rdfs:label="地点">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Resource"/>
        <rdfs:comment>表示地理位置</rdfs:comment>
    </rdfs:Class>

    <rdfs:Class rdf:ID="City" rdfs:label="城市">
        <rdfs:subClassOf rdf:resource="#Location"/>
        <rdfs:comment>表示城市</rdfs:comment>
    </rdfs:Class>

    <rdfs:Class rdf:ID="Country" rdfs:label="国家">
        <rdfs:subClassOf rdf:resource="#Location"/>
        <rdfs:comment>表示国家</rdfs:comment>
    </rdfs:Class>

    <rdfs:Class rdf:ID="InstitutionLocation" rdfs:label="机构所在地">
        <rdfs:subClassOf rdf:resource="#Location"/>
        <rdfs:comment>表示机构所在地，如大学校园、研究机构等</rdfs:comment>
    </rdfs:Class>

    <!-- 学术著作类及其子类 -->
    <rdfs:Class rdf:ID="Publication" rdfs:label="学术著作">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Resource"/>
        <rdfs:comment>表示图灵的学术著作</rdfs:comment>
    </rdfs:Class>

    <rdfs:Class rdf:ID="Paper" rdfs:label="论文">
        <rdfs:subClassOf rdf:resource="#Publication"/>
        <rdfs:comment>表示学术论文</rdfs:comment>
    </rdfs:Class>

    <rdfs:Class rdf:ID="Book" rdfs:label="书籍">
        <rdfs:subClassOf rdf:resource="#Publication"/>
        <rdfs:comment>表示书籍</rdfs:comment>
    </rdfs:Class>

    <rdfs:Class rdf:ID="TechnicalReport" rdfs:label="技术报告">
        <rdfs:subClassOf rdf:resource="#Publication"/>
        <rdfs:comment>表示技术报告</rdfs:comment>
    </rdfs:Class>

    <!-- 荣誉奖项类及其子类 -->
    <rdfs:Class rdf:ID="Award" rdfs:label="荣誉奖项">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Resource"/>
        <rdfs:comment>表示荣誉和奖项</rdfs:comment>
    </rdfs:Class>

    <rdfs:Class rdf:ID="AcademicAward" rdfs:label="学术奖项">
        <rdfs:subClassOf rdf:resource="#Award"/>
        <rdfs:comment>表示学术性质的奖项，如院士称号</rdfs:comment>
    </rdfs:Class>

    <rdfs:Class rdf:ID="HonoraryTitle" rdfs:label="荣誉称号">
        <rdfs:subClassOf rdf:resource="#Award"/>
        <rdfs:comment>表示荣誉称号，如勋章、赦免等</rdfs:comment>
    </rdfs:Class>

    <!-- 对象属性定义 -->
    <!-- 参与事件 -->
    <rdf:Property rdf:ID="participatedIn">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="#Event"/>
        <rdfs:label>参与事件</rdfs:label>
        <rdfs:comment>表示人物参与的事件</rdfs:comment>
    </rdf:Property>

    <!-- 位于某地 -->
    <rdf:Property rdf:ID="locatedIn">
        <rdfs:domain rdf:resource="#Location"/>
        <rdfs:range rdf:resource="#Location"/>
        <rdfs:label>位于某地</rdfs:label>
        <rdfs:comment>表示地点的层级关系</rdfs:comment>
    </rdf:Property>

    <!-- 撰写著作 -->
    <rdf:Property rdf:ID="wrote">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="#Publication"/>
        <rdfs:label>撰写著作</rdfs:label>
        <rdfs:comment>表示人物撰写的著作</rdfs:comment>
    </rdf:Property>

    <!-- 获得奖项 -->
    <rdf:Property rdf:ID="received">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="#Award"/>
        <rdfs:label>获得奖项</rdfs:label>
        <rdfs:comment>表示人物获得的奖项</rdfs:comment>
    </rdf:Property>

    <!-- 事件发生地点 -->
    <rdf:Property rdf:ID="happenedAt">
        <rdfs:domain rdf:resource="#Event"/>
        <rdfs:range rdf:resource="#Location"/>
        <rdfs:label>事件发生地点</rdfs:label>
        <rdfs:comment>表示事件发生的地点</rdfs:comment>
    </rdf:Property>

    <!-- 被提名奖项 -->
    <rdf:Property rdf:ID="nominatedFor">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="#Award"/>
        <rdfs:label>被提名奖项</rdfs:label>
        <rdfs:comment>表示人物被提名的奖项</rdfs:comment>
    </rdf:Property>

    <!-- 国家属性 -->
    <rdf:Property rdf:ID="country">
        <rdfs:domain rdf:resource="#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>所属国家</rdfs:label>
        <rdfs:comment>表示地点所属的国家</rdfs:comment>
    </rdf:Property>

    <!-- 数据类型属性定义 -->
    <!-- 事件日期 -->
    <rdf:Property rdf:ID="eventDate">
        <rdfs:domain rdf:resource="#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label>事件发生日期</rdfs:label>
        <rdfs:comment>表示事件发生的日期</rdfs:comment>
    </rdf:Property>

    <!-- 发表年份 -->
    <rdf:Property rdf:ID="publicationYear">
        <rdfs:domain rdf:resource="#Publication"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
        <rdfs:label>发表年份</rdfs:label>
        <rdfs:comment>表示著作发表的年份</rdfs:comment>
    </rdf:Property>

    <!-- 获奖年份 -->
    <rdf:Property rdf:ID="awardYear">
        <rdfs:domain rdf:resource="#Award"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
        <rdfs:label>获奖年份</rdfs:label>
        <rdfs:comment>表示奖项颁发的年份</rdfs:comment>
    </rdf:Property>

    <!-- 描述信息 -->
    <rdf:Property rdf:ID="description">
        <rdfs:domain rdf:resource="http://www.w3.org/2000/01/rdf-schema#Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>描述信息</rdfs:label>
        <rdfs:comment>表示对实体或事件的描述</rdfs:comment>
    </rdf:Property>

</rdf:RDF>
